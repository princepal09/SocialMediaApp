{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    "types": ["node"],

    "strict": true,

    "sourceMap": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force"
  },
  "include": ["src"]
}